{
  "connection": {
    "max_connections_per_ip": 8,
    "backend_connect_timeout_secs": 5
  },
  "rate_limit": {
    "window_secs": 2,
    "max_connects_per_window": 6,
    "max_connects_per_minute": 60
  },
  "protection": {
    "blacklist_duration_secs": 120,
    "whitelist_after_secs": 30,
    "strikes_before_ban": 2,
    "max_syn_per_sec": 50000,
    "subnet_strike_threshold": 3
  },
  "behavioral": {
    "enabled": true,
    "min_duration_secs": 5,
    "min_bytes_sent": 10,
    "min_bytes_recv": 10,
    "scoring_threshold": 10,
    "ban_on_threshold": true,
    "score_decay_interval_secs": 600
  },
  "geo": {
    "enabled": true,
    "asn_db_path": "geoip/GeoLite2-ASN.mmdb",
    "country_db_path": "geoip/GeoLite2-Country.mmdb",
    "datacenter_max_connects_per_minute": 3,
    "datacenter_keywords": [
      "digitalocean",
      "google",
      "hetzner",
      "ovh",
      "microsoft",
      "alibaba",
      "tencent",
      "vultr",
      "linode",
      "choopa",
      "m247",
      "contabo",
      "scaleway",
      "oracle",
      "leaseweb",
      "cogent",
      "psychz",
      "quadranet",
      "hostwinds",
      "buyvm",
      "ionos",
      "kamatera",
      "cherry servers",
      "hostinger",
      "racknerd",
      "cloudflare",
      "akamai",
      "fastly",
      "huawei cloud",
      "ucloud"
    ]
  }
}